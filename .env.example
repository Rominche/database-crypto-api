# PostgreSQL - database-crypto-api
# Copy to .env and replace with your values. Never commit .env (contains secrets).

POSTGRES_USER=dbuser
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=crypto_db

# Optional: override default port (default 5432)
# POSTGRES_PORT=5432

# Optional: PostgreSQL host for Flyway (default: postgres service name in docker-compose)
# POSTGRES_HOST=postgres
